# ==========================================
# Configurações do Banco de Dados
# ==========================================

# URL de conexão com o banco
# Dica local: jdbc:postgresql://db:5432/gerenciar-tarefas-db
# Dica nuvem: jdbc:postgresql://<host-do-supabase-ou-rds>:5432/<nome-do-banco>
DB_URL=jdbc:postgresql://<seu-host>:5432/<seu-banco>

# Usuário do banco
DB_USER=seu_usuario_aqui

# Senha do banco
DB_PASSWORD=sua_senha_secreta_aqui
